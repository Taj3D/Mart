/// Transaction — General financial transaction ledger
model Transaction {
  id              String   @id @default(cuid())
  code            String   @unique                                        // TXN-00001
  type            String                                                     // Credit, Debit
  amount          Float    @default(0)
  transactionDate DateTime @default(now())
  category        String?                                                     // Sales, Purchase, Expense, Income, Transfer, Adjustment
  referenceNo     String?
  description     String?
  relatedEntityType String?                                                  // SalesOrder, PurchaseOrder, Invoice, etc.
  relatedEntityId String?
  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)
  createdBy       String?
  createdDate     DateTime @default(now())
  updatedBy       String?
  updatedDate     DateTime @updatedAt

  @@index([code])
  @@index([type])
  @@index([category])
  @@index([transactionDate])
  @@index([relatedEntityType, relatedEntityId])
  @@index([isDeleted])
}

