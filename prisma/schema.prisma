  code           String   @unique                                       // BNA-00001
  bankName       String
  accountName    String
  accountNumber  String
  branch         String?
  routingNumber  String?
  swiftCode      String?
  balance        Float    @default(0)
  openingBalance Float    @default(0)
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
