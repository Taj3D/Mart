  updatedDate    DateTime @updatedAt

  transactions BankTransaction[]

  @@index([code])
  @@index([bankName])
  @@index([accountNumber])
  @@index([isDeleted])
}

/// BankTransaction — Bank account transaction ledger
model BankTransaction {
  id              String   @id @default(cuid())
  code            String   @unique                                      // BNT-00001
  bankAccountId   String
  type            String                                                     // Deposit, Withdrawal, Transfer, Interest, Fee
  amount          Float    @default(0)
  balanceAfter    Float    @default(0)
  transactionDate DateTime @default(now())
  referenceNo     String?
  description     String?
  relatedEntityType String?
  relatedEntityId String?
  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)
  createdBy       String?
  createdDate     DateTime @default(now())
  updatedBy       String?
  updatedDate     DateTime @updatedAt

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([code])
  @@index([bankAccountId])
  @@index([type])
  @@index([transactionDate])
  @@index([isDeleted])
}

/// SmsLog — SMS notification audit trail
model SmsLog {
  id          String   @id @default(cuid())
  recipient   String
  message     String
  status      String   @default("Queued")                                 // Queued, Sent, Delivered, Failed
  sentAt      DateTime @default(now())
  responseCode String?
  providerRef String?
  messageType String?                                                       // OTP, Notification, Alert, Marketing
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([sentAt])
  @@index([messageType])
  @@index([isDeleted])
}

/// NotificationLog — System notification audit trail
model NotificationLog {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  message     String
  type        String   @default("Info")                                   // Info, Warning, Error, Success
  isRead      Boolean  @default(false)
  readAt      DateTime?
  link        String?
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdDate])
  @@index([isDeleted])
}

// ============================================================================
// SECTOR 7: IDENTITY & ACCESS (3 Models)
// ============================================================================

/// User — System users with authentication
model User {
  id            String   @id @default(cuid())
  userName      String   @unique
  email         String?
  passwordHash  String
  fullName      String?
  role          String   @default("User")
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  isDeleted     Boolean  @default(false)
  createdDate   DateTime @default(now())
  updatedDate   DateTime @updatedAt

  auditLogs       AuditLog[]
  stockMovements  StockMovement[]

  @@index([userName])
  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([isDeleted])
}

/// AuditLog — Comprehensive audit trail
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String                                                       // Create, Update, Delete, Login, Logout, Export, Import
  entity      String                                                       // Model name (Product, Customer, etc.)
  entityId    String?
  oldValues   String?                                                       // JSON string of previous values
  newValues   String?                                                       // JSON string of new values
  ipAddress   String?
  userAgent   String?
  createdDate DateTime @default(now())
  isDeleted   Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([createdDate])
  @@index([isDeleted])
}

/// Setting — System configuration key-value store
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String?                                                       // General, Email, Sms, Payment, Report
  description String?
  isDeleted   Boolean  @default(false)
  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt

  @@index([key])
  @@index([category])
  @@index([isDeleted])
}

// ============================================================================
// SECTOR 8: BILLING & INVOICING (2 Models)
// ============================================================================

/// Invoice — Billing documents
model Invoice {
  id            String   @id @default(cuid())
  code          String   @unique                                          // INV-00001
  salesOrderId  String?
  customerId    String
  invoiceDate   DateTime @default(now())
  dueDate       DateTime?
  status        String   @default("Draft")                                 // Draft, Sent, Paid, PartiallyPaid, Overdue, Cancelled
  subtotal      Float    @default(0)
  taxAmount     Float    @default(0)
  discountAmount Float   @default(0)
  totalAmount   Float    @default(0)
  paidAmount    Float    @default(0)
  dueAmount     Float    @default(0)
  notes         String?
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  payments   Payment[]

  @@index([code])
  @@index([salesOrderId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([status])
  @@index([isDeleted])
}

/// Payment — Payment records
model Payment {
  id            String   @id @default(cuid())
  code          String   @unique                                          // PAY-00001
  invoiceId     String
  amount        Float    @default(0)
  paymentDate   DateTime @default(now())
  method        String   @default("Cash")                                 // Cash, Card, BankTransfer, Check, Mobile, EMI
  cardTypeId    String?
  referenceNo   String?
  notes         String?
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([code])
  @@index([invoiceId])
  @@index([paymentDate])
  @@index([method])
  @@index([isDeleted])
}

// ============================================================================
