/// StockMovement — Tracks all inventory movements for audit trail
model StockMovement {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  type        String                                                     // In, Out, Transfer, Adjustment, Return, Damage
  quantity    Int      @default(0)
  referenceNo String?
  referenceType String?                                                   // PurchaseOrder, SalesOrder, StockTransfer, etc.
  referenceId String?
  notes       String?
  movedBy     String?
  isDeleted   Boolean  @default(false)
  createdDate DateTime @default(now())

  product   Product   @relation(fields: [productId], references: [id])
