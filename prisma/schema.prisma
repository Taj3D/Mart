// ============================================================================
// Electronics Mart IMS — Enterprise Database Schema
// Phase 2: Database Schema & Core Data Models (58+ Corporate Models)
// ============================================================================
// Architecture: Fully normalized relational schema with:
//   - BaseEntity pattern (CreatedBy, CreatedDate, UpdatedBy, UpdatedDate, IsDeleted)
//   - Immutable 5-digit zero-padded auto record numbers (CUS-00001, PRT-00001, etc.)
//   - Strict Primary Keys, Foreign Keys, unique indices, cascade rules
//   - High-volume reporting indices for CSV/PDF bulk utilities
//   - Soft-delete shadow filter support (isDeleted)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// SECTOR 1: INVESTMENT & ASSETS (6 Models)
// ============================================================================

/// Investment Heads — Categories of investment portfolios
model InvestmentHead {
  id          String   @id @default(cuid())
  code        String   @unique                                          // INVH-00001
  name        String
  description String?
  type        String   @default("General")                              // General, RealEstate, Stock, Bond, Other
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  investments Investment[]

  @@index([code])
  @@index([type])
  @@index([isDeleted])
  @@index([isActive])
}

/// Investment — Individual investment entries
model Investment {
  id               String   @id @default(cuid())
  code             String   @unique                                     // INV-00001
  investmentHeadId String
  name             String
  amount           Float    @default(0)
  investmentDate   DateTime @default(now())
  maturityDate     DateTime?
  returnRate       Float    @default(0)
  returnValue      Float    @default(0)
  status           String   @default("Active")                           // Active, Matured, Withdrawn, Lost
  notes            String?
  isActive         Boolean  @default(true)
  isDeleted        Boolean  @default(false)
  createdBy        String?
  createdDate      DateTime @default(now())
  updatedBy        String?
  updatedDate      DateTime @updatedAt

  investmentHead InvestmentHead @relation(fields: [investmentHeadId], references: [id])

  @@index([code])
  @@index([investmentHeadId])
  @@index([status])
  @@index([investmentDate])
  @@index([isDeleted])
}

/// Asset — General asset tracking
model Asset {
  id            String   @id @default(cuid())
  code          String   @unique                                        // AST-00001
  name          String
  category      String   @default("General")                             // General, IT, Vehicle, Furniture, Other
  purchaseDate  DateTime @default(now())
  purchasePrice Float    @default(0)
  currentValue  Float    @default(0)
  status        String   @default("Active")                              // Active, Disposed, WrittenOff
  location      String?
  notes         String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  fixedAssets  FixedAsset[]
  currentAssets CurrentAsset[]

  @@index([code])
  @@index([category])
  @@index([status])
  @@index([isDeleted])
}

/// FixedAsset — Long-term depreciable assets
model FixedAsset {
  id                  String   @id @default(cuid())
  code                String   @unique                                 // FAX-00001
  assetId             String
  name                String
  purchaseDate        DateTime @default(now())
  purchasePrice       Float    @default(0)
  salvageValue        Float    @default(0)
  usefulLifeMonths    Int      @default(60)
  depreciationMethod  String   @default("StraightLine")                  // StraightLine, DecliningBalance
  currentBookValue    Float    @default(0)
  accumulatedDep      Float    @default(0)
  location            String?
  serialNo            String?
  warrantyExpiry      DateTime?
  isActive            Boolean  @default(true)
  isDeleted           Boolean  @default(false)
  createdBy           String?
  createdDate         DateTime @default(now())
  updatedBy           String?
  updatedDate         DateTime @updatedAt

  asset           Asset           @relation(fields: [assetId], references: [id])
  depreciationLogs DepreciationLog[]

  @@index([code])
  @@index([assetId])
  @@index([depreciationMethod])
  @@index([isDeleted])
}

/// CurrentAsset — Short-term liquid assets
model CurrentAsset {
  id            String   @id @default(cuid())
  code          String   @unique                                        // CAX-00001
  assetId       String
  name          String
  type          String   @default("Cash")                                // Cash, Receivable, Inventory, Prepaid
  amount        Float    @default(0)
  maturityDate  DateTime?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id])

  @@index([code])
  @@index([assetId])
  @@index([type])
  @@index([isDeleted])
}

/// DepreciationLog — Tracks depreciation entries over time
model DepreciationLog {
  id                 String   @id @default(cuid())
  fixedAssetId       String
  period             String                                                 // "2024-01", "2024-02", etc.
  depreciationAmount Float    @default(0)
  bookValue          Float    @default(0)
  method             String   @default("StraightLine")
  notes              String?
  isDeleted          Boolean  @default(false)
  createdBy          String?
  createdDate        DateTime @default(now())
  updatedBy          String?
  updatedDate        DateTime @updatedAt

  fixedAsset FixedAsset @relation(fields: [fixedAssetId], references: [id])

  @@index([fixedAssetId])
  @@index([period])
  @@index([isDeleted])
}

// ============================================================================
// SECTOR 2: LIABILITIES (3 Models)
// ============================================================================

/// Liability — Outstanding liabilities (loans, payables)
model Liability {
  id           String   @id @default(cuid())
  code         String   @unique                                           // LIA-00001
  name         String
  type         String   @default("Loan")                                   // Loan, Payable, Mortgage, Other
  principalAmount Float @default(0)
  interestRate Float    @default(0)
  outstandingAmount Float @default(0)
  startDate    DateTime @default(now())
  dueDate      DateTime?
  status       String   @default("Active")                                 // Active, Settled, Defaulted
  creditorName String?
  notes        String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdBy    String?
  createdDate  DateTime @default(now())
  updatedBy    String?
  updatedDate  DateTime @updatedAt

  transactions LiabilityTransaction[]
  payments     LiabilityPayment[]

  @@index([code])
  @@index([type])
  @@index([status])
  @@index([dueDate])
  @@index([isDeleted])
}

/// LiabilityTransaction — Transactions against liabilities
model LiabilityTransaction {
  id          String   @id @default(cuid())
  liabilityId String
  type        String                                                     // Disbursement, Accrual, Adjustment
  amount      Float    @default(0)
  transactionDate DateTime @default(now())
  referenceNo String?
  notes       String?
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  liability Liability @relation(fields: [liabilityId], references: [id])

  @@index([liabilityId])
  @@index([transactionDate])
  @@index([isDeleted])
}

/// LiabilityPayment — Payments made towards liabilities
model LiabilityPayment {
  id            String   @id @default(cuid())
  code          String   @unique                                         // LPY-00001
  liabilityId   String
  amount        Float    @default(0)
  principalPart Float    @default(0)
  interestPart  Float    @default(0)
  paymentDate   DateTime @default(now())
  method        String   @default("Cash")                                 // Cash, Bank, Check, Online
  referenceNo   String?
  notes         String?
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  liability Liability @relation(fields: [liabilityId], references: [id])

  @@index([code])
  @@index([liabilityId])
  @@index([paymentDate])
  @@index([isDeleted])
}

// ============================================================================
// SECTOR 3: BASIC FOUNDATION & CRM (17 Models)
// ============================================================================

/// Company — Organization master record
model Company {
  id            String   @id @default(cuid())
  code          String   @unique                                           // CMP-00001
  name          String
  address       String?
  phone         String?
  email         String?
  website       String?
  logo          String?
  currency      String   @default("BDT")
  financialYear String?
  taxId         String?
  registrationNo String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  @@index([code])
  @@index([name])
  @@index([isDeleted])
}

/// Category — Self-referencing product category tree
model Category {
  id          String   @id @default(cuid())
  code        String   @unique                                             // CAT-00001
  name        String
  description String?
  parentId    String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([code])
  @@index([parentId])
  @@index([isDeleted])
}

/// Color — Product color master
model Color {
  id          String   @id @default(cuid())
  code        String   @unique                                             // CLR-00001
  name        String
  hexCode     String?                                                       // #FF0000
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  productColors ProductColor[]

  @@index([code])
  @@index([isDeleted])
}

/// Brand — Product brand master
model Brand {
  id          String   @id @default(cuid())
  code        String   @unique                                             // BRD-00001
  name        String
  description String?
  logo        String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  products Product[]

  @@index([code])
  @@index([name])
  @@index([isDeleted])
}

/// Unit — Measurement units
model Unit {
  id          String   @id @default(cuid())
  code        String   @unique                                             // UNT-00001
  name        String
  symbol      String?                                                       // pcs, kg, ltr, m
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  products Product[]

  @@index([code])
  @@index([isDeleted])
}

/// Warehouse (Godown) — Storage locations
model Warehouse {
  id          String   @id @default(cuid())
  code        String   @unique                                             // WHS-00001
  name        String
  address     String?
  phone       String?
  managerName String?
  type        String   @default("General")                                  // General, ColdStorage, Hazardous
  capacity    Int?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  warehouseStocks   WarehouseStock[]
  stockDetails      StockDetail[]
  stockAdjustments  StockAdjustment[]
  damageProducts    DamageProduct[]
  transfersFrom     StockTransfer[]       @relation("TransferFrom")
  transfersTo       StockTransfer[]       @relation("TransferTo")
  stockMovements    StockMovement[]

  @@index([code])
  @@index([name])
  @@index([isDeleted])
}

/// Segment — Market / product segmentation
model Segment {
  id          String   @id @default(cuid())
  code        String   @unique                                             // SEG-00001
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  productSegments ProductSegment[]

  @@index([code])
  @@index([isDeleted])
}

/// Capacity — Product capacity specifications (e.g., 256GB, 1.5Ton, 320L)
model Capacity {
  id          String   @id @default(cuid())
  code        String   @unique                                             // CAP-00001
  name        String
  value       Float    @default(0)
  unit        String?                                                       // GB, Ton, L, kWh
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  productCapacities ProductCapacity[]

  @@index([code])
  @@index([isDeleted])
}

/// SrTarget — Sales Representative targets
model SrTarget {
  id             String   @id @default(cuid())
  code           String   @unique                                          // SRT-00001
  employeeId     String
  targetAmount   Float    @default(0)
  achievedAmount Float    @default(0)
  period         String                                                     // Monthly, Quarterly, Yearly
  year           Int
  month          Int?
  quarter        Int?
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdBy      String?
  createdDate    DateTime @default(now())
  updatedBy      String?
  updatedDate    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([code])
  @@index([employeeId])
  @@index([year, month])
  @@index([isDeleted])
}

/// PaymentOption — Available payment methods
model PaymentOption {
  id          String   @id @default(cuid())
  code        String   @unique                                             // POP-00001
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  @@index([code])
  @@index([isDeleted])
}

/// CardType — Credit/debit card type master
model CardType {
  id          String   @id @default(cuid())
  code        String   @unique                                             // CDT-00001
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  @@index([code])
  @@index([isDeleted])
}

/// Customer — Clients who purchase electronics
model Customer {
  id             String   @id @default(cuid())
  code           String   @unique                                          // CUS-00001
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  country        String   @default("Bangladesh")
  creditLimit    Float    @default(0)
  balance        Float    @default(0)
  openingBalance Float    @default(0)
  customerType   String   @default("Regular")                               // Regular, Wholesale, Corporate, Dealer
  nid            String?                                                       // National ID
  tradeLicense   String?
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdBy      String?
  createdDate    DateTime @default(now())
  updatedBy      String?
  updatedDate    DateTime @updatedAt

  salesOrders    SalesOrder[]
  salesReturns   SalesReturn[]
  orderSheets    OrderSheet[]
  cashCollections CashCollection[]
  invoices       Invoice[]

  @@index([code])
  @@index([name])
  @@index([phone])
  @@index([customerType])
  @@index([isDeleted])
}

/// Supplier — Vendors who supply goods
model Supplier {
  id             String   @id @default(cuid())
  code           String   @unique                                          // SUP-00001
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  country        String   @default("Bangladesh")
  balance        Float    @default(0)
  openingBalance Float    @default(0)
  supplierType   String   @default("Regular")                               // Regular, Manufacturer, Distributor, Importer
  nid            String?
  tradeLicense   String?
  bankName       String?
  bankAccount    String?
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdBy      String?
  createdDate    DateTime @default(now())
  updatedBy      String?
  updatedDate    DateTime @updatedAt

  purchaseOrders  PurchaseOrder[]
  purchaseReturns PurchaseReturn[]
  cashDeliveries  CashDelivery[]

  @@index([code])
  @@index([name])
  @@index([phone])
  @@index([supplierType])
  @@index([isDeleted])
}

/// Employee — Staff management
model Employee {
  id          String   @id @default(cuid())
  code        String   @unique                                             // EMP-00001
  firstName   String
  lastName    String
  email       String?
  phone       String?
  address     String?
  departmentId String?
  designationId String?
  joinDate    DateTime @default(now())
  endDate     DateTime?
  salary      Float    @default(0)
  nid         String?
  bloodGroup  String?
  emergencyContact String?
  photo       String?
  status      String   @default("Active")                                   // Active, OnLeave, Resigned, Terminated
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  department   Department?  @relation(fields: [departmentId], references: [id])
  designation  Designation? @relation(fields: [designationId], references: [id])
  leaves       EmployeeLeave[]
  srTargets    SrTarget[]

  @@index([code])
  @@index([departmentId])
  @@index([designationId])
  @@index([status])
  @@index([isDeleted])
}

/// Designation — Job titles / positions
model Designation {
  id          String   @id @default(cuid())
  code        String   @unique                                             // DSG-00001
  name        String
  description String?
  grade       String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  employees Employee[]

  @@index([code])
  @@index([isDeleted])
}

/// Department — Organizational departments
model Department {
  id          String   @id @default(cuid())
  code        String   @unique                                             // DEP-00001
  name        String
  description String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  employees Employee[]

  @@index([code])
  @@index([isDeleted])
}

/// EmployeeLeave — Leave tracking
model EmployeeLeave {
  id          String   @id @default(cuid())
  code        String   @unique                                             // LV-00001
  employeeId  String
  leaveType   String                                                       // Casual, Sick, Earned, Maternity, Paternity, Unpaid
  startDate   DateTime
  endDate     DateTime
  totalDays   Int      @default(0)
  status      String   @default("Pending")                                  // Pending, Approved, Rejected, Cancelled
  reason      String?
  approvedBy  String?
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  createdBy   String?
  createdDate DateTime @default(now())
  updatedBy   String?
  updatedDate DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([code])
  @@index([employeeId])
  @@index([leaveType])
  @@index([startDate, endDate])
  @@index([status])
  @@index([isDeleted])
}

// ============================================================================
// SECTOR 4: PRODUCT & INVENTORY CORE (5 Models)
// ============================================================================

/// Product — Master inventory items (TV, Fridge, AC, Mobile, etc.)
model Product {
  id            String   @id @default(cuid())
  code          String   @unique                                           // PRT-00001
  sku           String?  @unique
  name          String
  description   String?
  categoryId    String?
  brandId       String?
  unitId        String?
  modelNo       String?
  costPrice     Float    @default(0)
  sellPrice     Float    @default(0)
  wholesalePrice Float   @default(0)
  minStock      Int      @default(0)
  maxStock      Int      @default(0)
  currentStock  Int      @default(0)
  warrantyMonths Int     @default(0)
  image         String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  category           Category?            @relation(fields: [categoryId], references: [id])
  brand              Brand?               @relation(fields: [brandId], references: [id])
  unit               Unit?                @relation(fields: [unitId], references: [id])
  productColors      ProductColor[]
  productSegments    ProductSegment[]
  productCapacities  ProductCapacity[]
  productImages      ProductImage[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]
  orderSheetItems    OrderSheetItem[]
  stockDetails       StockDetail[]
  warehouseStocks    WarehouseStock[]
  stockAdjustments   StockAdjustment[]
  stockMovements     StockMovement[]
  salesReturnItems   SalesReturnItem[]
  purchaseReturnItems PurchaseReturnItem[]
  damageProducts     DamageProduct[]
  transferItems      TransferItem[]

  @@index([code])
  @@index([sku])
  @@index([categoryId])
  @@index([brandId])
  @@index([name])
  @@index([isActive])
  @@index([isDeleted])
}

/// ProductColor — Color variant mapping
model ProductColor {
  id        String @id @default(cuid())
  productId String
  colorId   String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  color   Color   @relation(fields: [colorId], references: [id])

  @@unique([productId, colorId])
  @@index([productId])
  @@index([colorId])
}

/// ProductSegment — Segment mapping
model ProductSegment {
  id        String @id @default(cuid())
  productId String
  segmentId String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  segment Segment @relation(fields: [segmentId], references: [id])

  @@unique([productId, segmentId])
  @@index([productId])
  @@index([segmentId])
}

/// ProductCapacity — Capacity variant mapping
model ProductCapacity {
  id         String @id @default(cuid())
  productId  String
  capacityId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  capacity Capacity @relation(fields: [capacityId], references: [id])

  @@unique([productId, capacityId])
  @@index([productId])
  @@index([capacityId])
}

/// ProductImage — Product image gallery
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  imageUrl  String
  altText   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([sortOrder])
}

// ============================================================================
// SECTOR 5: OPERATIONAL LOGISTICS (14 Models)
// ============================================================================

/// OrderSheet — Pre-order planning / demand collection
model OrderSheet {
  id           String   @id @default(cuid())
  code         String   @unique                                           // OS-00001
  customerId   String?
  orderDate    DateTime @default(now())
  deliveryDate DateTime?
  status       String   @default("Draft")                                  // Draft, Confirmed, Processed, Cancelled
  totalAmount  Float    @default(0)
  notes        String?
  isActive     Boolean  @default(true)
  isDeleted    Boolean  @default(false)
  createdBy    String?
  createdDate  DateTime @default(now())
  updatedBy    String?
  updatedDate  DateTime @updatedAt

  customer Customer?      @relation(fields: [customerId], references: [id])
  items    OrderSheetItem[]

  @@index([code])
  @@index([customerId])
  @@index([orderDate])
  @@index([status])
  @@index([isDeleted])
}

/// OrderSheetItem — Line items in an order sheet
model OrderSheetItem {
  id           String  @id @default(cuid())
  orderSheetId String
  productId    String
  quantity     Int     @default(0)
  unitPrice    Float   @default(0)
  totalPrice   Float   @default(0)
  notes        String?

  orderSheet OrderSheet @relation(fields: [orderSheetId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([orderSheetId])
  @@index([productId])
}

/// PurchaseOrder — Orders to suppliers
model PurchaseOrder {
  id            String   @id @default(cuid())
  code          String   @unique                                          // PO-00001
  supplierId    String
  orderDate     DateTime @default(now())
  expectedDate  DateTime?
  receivedDate  DateTime?
  status        String   @default("Pending")                               // Pending, Approved, PartiallyReceived, Received, Cancelled
  subtotal      Float    @default(0)
  taxAmount     Float    @default(0)
  discountAmount Float   @default(0)
  totalAmount   Float    @default(0)
  paidAmount    Float    @default(0)
  notes         String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
  createdBy     String?
  createdDate   DateTime @default(now())
  updatedBy     String?
  updatedDate   DateTime @updatedAt

  supplier      Supplier           @relation(fields: [supplierId], references: [id])
  items         PurchaseOrderItem[]
  purchaseReturns PurchaseReturn[]

  @@index([code])
  @@index([supplierId])
  @@index([orderDate])
  @@index([status])
  @@index([isDeleted])
}

/// PurchaseOrderItem — Line items in a purchase order
model PurchaseOrderItem {
