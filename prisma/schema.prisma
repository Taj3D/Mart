/// DamageProduct — Damaged inventory tracking
model DamageProduct {
  id            String   @id @default(cuid())
  code          String   @unique                                          // DMG-00001
  productId     String
  warehouseId   String
  quantity      Int      @default(0)
  damageDate    DateTime @default(now())
  damageType    String                                                     // Manufacturing, Transit, Storage, CustomerReported, Other
  description   String?
  estimatedLoss Float    @default(0)
  status        String   @default("Reported")                              // Reported, Verified, WrittenOff, Replaced
  notes         String?
  isActive      Boolean  @default(true)
  isDeleted     Boolean  @default(false)
