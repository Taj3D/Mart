/// WarehouseStock — Aggregate stock per warehouse per product
model WarehouseStock {
  id                String @id @default(cuid())
  productId         String
  warehouseId       String
  quantity          Int    @default(0)
  reservedQuantity  Int    @default(0)
  availableQuantity Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
}

/// StockTransfer — Transfer stock between warehouses
model StockTransfer {
  id             String   @id @default(cuid())
  code           String   @unique                                        // TRF-00001
  fromWarehouseId String
  toWarehouseId  String
  transferDate   DateTime @default(now())
  status         String   @default("Pending")                              // Pending, InTransit, Received, Cancelled
  notes          String?
  isActive       Boolean  @default(true)
  isDeleted      Boolean  @default(false)
  createdBy      String?
  createdDate    DateTime @default(now())
  updatedBy      String?
  updatedDate    DateTime @updatedAt

  fromWarehouse Warehouse     @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse     @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items         TransferItem[]

  @@index([code])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([transferDate])
  @@index([status])
  @@index([isDeleted])
}

/// TransferItem — Items in a stock transfer
model TransferItem {
  id              String @id @default(cuid())
  stockTransferId String
  productId       String
  quantity        Int    @default(0)
  receivedQty     Int    @default(0)
  notes           String?

  stockTransfer StockTransfer @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@index([stockTransferId])
  @@index([productId])
}

/// StockAdjustment — Manual stock adjustments
model StockAdjustment {
  id             String   @id @default(cuid())
  code           String   @unique                                        // ADJ-00001
  productId      String
  warehouseId    String
  adjustmentType String                                                     // In, Out, Set
